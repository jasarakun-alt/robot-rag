# ---- LLM (Ollama) ----
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=qwen2.5:14b
LLM_TEMPERATURE=0.1

# ---- Embedding ----
# EMBEDDING_BACKEND: "sentence-transformers" (realni, večjezični) ali "hash" (offline/dev, brez torch)
EMBEDDING_BACKEND=sentence-transformers
EMBEDDING_MODEL=intfloat/multilingual-e5-small

# ---- Retrieval ----
TOP_K=3
# MANUAL_PATH=./data/prirocnik.md   # privzeto se razreši samodejno glede na repo

# ---- Naslovi storitev (lokalno) ----
EMBEDDING_SERVICE_URL=http://localhost:8001
RETRIEVAL_SERVICE_URL=http://localhost:8002
LLM_SERVICE_URL=http://localhost:8003
